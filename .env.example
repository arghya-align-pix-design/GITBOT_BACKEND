# ── Database (Neon Postgres) ──────────────────────────────
# Pooled connection string (used at runtime)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Direct connection string (used for Prisma migrations)
DIRECT_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# ── Auth Bridge ───────────────────────────────────────────
# Must match AUTH_SECRET in the frontend .env.local
NEXTAUTH_SECRET=your_32_byte_base64_auth_secret

# ── GitHub Webhook ────────────────────────────────────────
# Secret used to sign/verify webhook payloads (generate with: openssl rand -base64 32)
GITHUB_WEBHOOK_SECRET=your_random_github_webhook_hmac_secret

# ── Server ────────────────────────────────────────────────
# Public URL where GitHub can reach this backend's webhook endpoint (e.g. ngrok or deployed VPS)
BACKEND_PUBLIC_URL=https://api.yourdomain.com

# Frontend origin for CORS whitelist
FRONTEND_URL=https://gitbot-frontend.vercel.app

PORT=8000

# ── Slack ────────────────────────────────────────────────
# Optional Slack webhook URL for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_SLACK_WEBHOOK_PATH

